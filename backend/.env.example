# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/supportflow

# CORS — frontend origin (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# API
API_VERSION=0.1.0

# JWT — REQUIRED in production (server refuses to start without JWT_SECRET)
JWT_SECRET=your-secret-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# Password hashing — defaults to 10 in development, 12 in production when unset
BCRYPT_ROUNDS=10
